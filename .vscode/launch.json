    "version": "0.2.0",
    "configurations": [
        {
            "type": "cppdbg",
            "request": "launch",
            "name": "Debug",
            "program": "${workspaceFolder}/out/build/linux-x64/bin/Debug/openvic-dataloader.headless",
            "args": ["csv", "./output.csv"],
            "cwd": "${workspaceFolder}/out/build/linux-x64/bin/Debug",
            "preLaunchTask": "build",
            "windows": {
                "type": "cppvsdbg",
                "request": "launch",
                "name": "Debug",
                "program": "${workspaceFolder}\\out\\build\\windows-x64-md\\bin\\Debug\\openvic-dataloader.headless.exe",
                "args": ["csv", "./output.csv"],
                "cwd": "${workspaceFolder}\\out\\build\\windows-x64-md\\bin\\Debug",
                "preLaunchTask": "build",
            },
            "osx": {
                "type": "cppdbg",
                "request": "launch",
                "name": "Debug",
                "program": "${workspaceFolder}/out/build/macos-universal/bin/Debug/openvic-dataloader.headless",
                "args": ["csv", "./output.csv"],
                "cwd": "${workspaceFolder}/out/build/macos-universal/bin/Debug",
                "preLaunchTask": "build",
            }
        }
    ]
}
