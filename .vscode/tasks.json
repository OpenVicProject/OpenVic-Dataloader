{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "configure",
            "group": "build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "windows-x64-md"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build",
            "group": "build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "windows-x64-md-debug"
            ],
            "dependsOn": [
                "configure"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean",
            "group": "build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "windows-x64-md-debug",
                "--target",
                "clean"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "rebuild",
            "group": "build",
            "type": "shell",
            "dependsOn": [
                "clean",
                "build"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
