#!/usr/bin/env python

Import("env")


def build_lexy(env):
    env.Append(CPPDEFINES=["LEXY_HAS_UNICODE_DATABASE=1"])

    lexy_env, _ = env.BuildDependencyLibrary(target="lexy_file", src_dir="lexy/src", include_dir="lexy/include")

    # Require C++20
    if lexy_env.get("is_msvc", False):
        lexy_env.Append(CXXFLAGS=["/std:c++20"])

        lexy_env.Append(CXXFLAGS=["/WX", "/W3", "/D", "_CRT_SECURE_NO_WARNINGS"])
        if not lexy_env.get("use_clang_cl"):
            lexy_env.Append(CXXFLAGS=["/wd5105"])
    else:
        lexy_env.Append(CXXFLAGS=["-std=c++20"])

        lexy_env.Append(
            CXXFLAGS=["-pedantic-errors", "-Werror", "-Wall", "-Wextra", "-Wconversion", "-Wsign-conversion"]
        )
        if lexy_env["CXX"] == "clang++":
            lexy_env.Append(CXXFLAGS=["-Wno-shift-op-parentheses", "-Wno-parentheses-equality"])
        else:
            lexy_env.Append(
                CXXFLAGS=[
                    "-Wno-parentheses",
                    "-Wno-unused-local-typedefs",
                    "-Wno-array-bounds",  # , "-Wno-maybe-uninitialized", "-Wno-restrict"
                ]
            )


def build_dryad(env):
    include_dir = env.AddLibraryIncludes("dryad/include")
    if env.get("is_msvc", False):
        env.AppendUnique(CXXFLAGS=[f"/external:I{env.Dir(include_dir)}", "/external:W0"])
    else:
        env.Append(CXXFLAGS=["-isystem", env.Dir(include_dir)])


def build_fmt(env):
    fmt_env, _ = env.BuildDependencyLibrary(
        target="fmt",
        src_dir="fmt/src",
        include_dir="fmt/include",
        glob="*.cc",
        exclude="fmt.cc",
    )

    # Require C++20
    if fmt_env.get("is_msvc", False):
        fmt_env.Append(CXXFLAGS=["/std:c++20"])

        fmt_env.Append(CXXFLAGS=["/WX", "/W3", "/D", "_CRT_SECURE_NO_WARNINGS"])
    else:
        fmt_env.Append(CXXFLAGS=["-std=c++20"])

        fmt_env.Append(CXXFLAGS=["-Werror", "-Wall", "-Wextra", "-pedantic", "-Wconversion", "-Wundef"])
        if fmt_env["CXX"] == "clang++":
            fmt_env.Append(CXXFLAGS=["-Wweak-vtables", "-Wshadow", "-Wno-gnu-zero-variadic-macro-arguments"])
        else:
            fmt_env.Append(
                CXXFLAGS=[
                    "-Wold-style-cast",
                    "-Wundef",
                    "-Wredundant-decls",
                    "-Wwrite-strings",
                    "-Wpointer-arith",
                    "-Wcast-qual",
                    "-Wformat=2",
                    "-Wmissing-include-dirs",
                    "-Wcast-align",
                    "-Wctor-dtor-privacy",
                    "-Wdisabled-optimization",
                    "-Winvalid-pch",
                    "-Woverloaded-virtual",
                    "-Wconversion",
                    "-Wundef",
                    "-Wno-ctor-dtor-privacy",
                    "-Wno-format-nonliteral",
                    "-Wno-dangling-else",
                    "-Wno-unused-local-typedefs",
                    "-Wdouble-promotion",
                    "-Wtrampolines",
                    "-Wzero-as-null-pointer-constant",
                    "-Wuseless-cast",
                    "-Wvector-operation-performance",
                    "-Wsized-deallocation",
                    "-Wshadow",
                    "-Wshift-overflow=2",
                    "-Wnull-dereference",
                    "-Wduplicated-cond",
                ]
            )


def build_range_v3(env):
    include_dir = env.AddLibraryIncludes("range-v3/include")
    if env.get("is_msvc", False):
        env.AppendUnique(CXXFLAGS=[f"/external:I{env.Dir(include_dir)}", "/external:W0"])
    else:
        env.Append(CXXFLAGS=["-isystem", env.Dir(include_dir)])


def build_vmcontainer(env):
    env.BuildDependencyLibrary(
        target="vmcontainer",
        src_dir="vmcontainer/lib/src",
        include_dir="vmcontainer/lib/include",
    )


build_dryad(env)
build_fmt(env)
build_lexy(env)
build_range_v3(env)
build_vmcontainer(env)
